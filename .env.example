# 1. DATABASE CORE (PostgreSQL)
# Ganti dengan kredensial database produksi Anda (Supabase / Neon / Local VPS)
DATABASE_URL="postgresql://username:password@host:5432/xarvionex_core?schema=public"

# 2. WEBHOOK SECURITY LAYER
# Digunakan oleh bot WhatsApp otonom untuk transmisi data yang aman
XARVIONEX_WEBHOOK_SECRET="generate_a_very_long_random_string_here_for_security"

# 3. SYSTEM TELEMETRY
NODE_ENV="production"
NEXT_PUBLIC_APP_URL="https://xarvionex.com"

# 4. BOT INTEGRATION (FUTURE PREPARATION)
